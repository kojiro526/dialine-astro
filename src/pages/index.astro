---
import Layout from '../layouts/Layout.astro';
import { listDiaryDays, listEntries } from '../lib/published-content';
import { withBasePath } from '../lib/site-path';
import { loadSiteMetadata } from '../lib/site-metadata';

const latestDays = listDiaryDays().slice(0, 14);
const latestEntries = listEntries().slice(0, 20);
const siteMetadata = loadSiteMetadata();
const homeIntroLines = siteMetadata.home.intro.split('\n');
---

<Layout title={siteMetadata.home.pageTitle} description={siteMetadata.home.pageDescription}>
	<main class="content-shell py-8 sm:py-10 lg:py-12">
		<header class="max-w-3xl pb-8 sm:pb-10">
			<p class="section-label">Published journal</p>
			<h1 class="mt-3 text-3xl font-semibold tracking-normal text-ink sm:text-4xl">
				{siteMetadata.home.headline}
			</h1>
			<p class="mt-4 max-w-2xl text-base leading-8 text-muted">
				{homeIntroLines.map((line, index) => (
					<>
						{line}
						{index < homeIntroLines.length - 1 ? <br /> : null}
					</>
				))}
			</p>
		</header>

		<section class="grid gap-5 lg:grid-cols-[minmax(0,1.42fr)_minmax(320px,0.8fr)] lg:items-start">
			<article class="surface-panel p-4 sm:p-5">
				<div class="flex items-center justify-between gap-4 border-b border-line pb-3">
					<div>
						<p class="section-label">Entries</p>
						<h2 class="mt-1 text-xl font-semibold tracking-normal text-ink">{siteMetadata.home.latestEntriesHeading}</h2>
					</div>
					<span class="rounded-md border border-line bg-paper-soft px-2.5 py-1 text-xs font-medium text-muted">{latestEntries.length}</span>
				</div>
				{
					latestEntries.length === 0 ? (
						<p class="py-6 text-sm text-muted">{siteMetadata.home.emptyEntriesText}</p>
					) : (
						<ul class="divide-y divide-line/70">
							{latestEntries.map((entry) => (
								<li class="grid gap-2 py-3 sm:grid-cols-[7.5rem_minmax(0,1fr)] sm:items-start">
									<time class="metadata-text whitespace-nowrap" datetime={entry.entryAt ?? entry.updatedAt ?? entry.createdAt ?? `${entry.date}T${entry.time}:00Z`} data-format="logical-date-time" data-logical-date={entry.date}>{entry.date} {entry.time}</time>
									<div class="min-w-0">
										<a class="quiet-link block font-medium" href={withBasePath(entry.permalink)}>{entry.title}</a>
										<p class="mt-1 overflow-hidden text-ellipsis whitespace-nowrap text-sm text-muted">{entry.excerpt || entry.title}</p>
									</div>
								</li>
							))}
						</ul>
					)
				}
			</article>

			<article class="surface-panel p-4 sm:p-5">
				<div class="flex items-center justify-between gap-4 border-b border-line pb-3">
					<div>
						<p class="section-label">Days</p>
						<h2 class="mt-1 text-xl font-semibold tracking-normal text-ink">{siteMetadata.home.latestDaysHeading}</h2>
					</div>
					<span class="rounded-md border border-line bg-paper-soft px-2.5 py-1 text-xs font-medium text-muted">{latestDays.length}</span>
				</div>
				{
					latestDays.length === 0 ? (
						<p class="py-6 text-sm text-muted">{siteMetadata.home.emptyDaysText}</p>
					) : (
						<ul class="divide-y divide-line/70">
							{latestDays.map((day) => (
								<li class="flex items-baseline justify-between gap-4 py-3">
									<a class="quiet-link font-medium" href={withBasePath(day.permalink)}>{day.title}</a>
									<time class="metadata-text whitespace-nowrap" datetime={`${day.date}T00:00:00Z`} data-format="logical-date" data-logical-date={day.date}>{day.date}</time>
								</li>
							))}
						</ul>
					)
				}
			</article>
		</section>
	</main>
</Layout>
