---
import Layout from '../layouts/Layout.astro';
import { listDiaryDays, listEntries } from '../lib/published-content';
import { withBasePath } from '../lib/site-path';
import { loadSiteMetadata } from '../lib/site-metadata';

const latestDays = listDiaryDays().slice(0, 14);
const latestEntries = listEntries().slice(0, 20);
const siteMetadata = loadSiteMetadata();
const homeIntroLines = siteMetadata.home.intro.split('\n');
---

<Layout title={siteMetadata.home.pageTitle} description={siteMetadata.home.pageDescription}>
	<main class="container">
		<section class="hero">
			<h1>{siteMetadata.home.headline}</h1>
			<p>
				{homeIntroLines.map((line, index) => (
					<>
						{line}
						{index < homeIntroLines.length - 1 ? <br /> : null}
					</>
				))}
			</p>
		</section>

		<section class="panel-grid">
			<article class="panel">
				<h2>{siteMetadata.home.latestDaysHeading}</h2>
				{
					latestDays.length === 0 ? (
						<p class="empty">{siteMetadata.home.emptyDaysText}</p>
					) : (
						<ul>
							{latestDays.map((day) => (
								<li>
									<a href={withBasePath(day.permalink)}>{day.title}</a>
									<span>{day.date}</span>
								</li>
							))}
						</ul>
					)
				}
			</article>

			<article class="panel">
				<h2>{siteMetadata.home.latestEntriesHeading}</h2>
				{
					latestEntries.length === 0 ? (
						<p class="empty">{siteMetadata.home.emptyEntriesText}</p>
					) : (
						<ul>
							{latestEntries.map((entry) => (
								<li>
									<a href={withBasePath(entry.permalink)}>{entry.title}</a>
									<span>{entry.date} {entry.time}</span>
								</li>
							))}
						</ul>
					)
				}
			</article>
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 980px;
		margin: 0 auto;
		padding: 8px 16px 56px;
	}

	.hero {
		border-radius: 18px;
		border: 1px solid var(--line-soft);
		background: linear-gradient(135deg, #fffdf8 0%, #f6f0e2 100%);
		padding: 20px;
		box-shadow: var(--shadow-soft);
	}

	.hero h1 {
		margin: 0;
		font-size: 2rem;
		letter-spacing: 0.02em;
	}

	.hero p {
		margin: 12px 0 0;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.panel-grid {
		display: grid;
		gap: 18px;
		margin-top: 18px;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.panel {
		border: 1px solid var(--line-soft);
		border-radius: 14px;
		background: var(--surface-elevated);
		padding: 16px;
	}

	.panel h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	.panel ul {
		list-style: none;
		margin: 12px 0 0;
		padding: 0;
		display: grid;
		gap: 10px;
	}

	.panel li {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		align-items: baseline;
	}

	.panel a {
		text-decoration: none;
		font-weight: 600;
		color: var(--text-strong);
	}

	.panel a:hover {
		color: var(--accent);
		text-decoration: underline;
	}

	.panel span {
		color: var(--text-muted);
		font-size: 0.85rem;
		white-space: nowrap;
	}

	.empty {
		margin-top: 12px;
		color: var(--text-muted);
	}

	@media (max-width: 900px) {
		.panel-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
