---
import Layout from '../layouts/Layout.astro';
import { listEntries } from '../lib/published-content';
import { withBasePath } from '../lib/site-path';
import { loadSiteMetadata } from '../lib/site-metadata';

const entries = listEntries();
const siteMetadata = loadSiteMetadata();
const groups = new Map<string, typeof entries>();

for (const entry of entries) {
  const key = entry.date.slice(0, 7);
  const current = groups.get(key) ?? [];
  current.push(entry);
  groups.set(key, current);
}
---

<Layout
  title={`${siteMetadata.archive.pageTitle} | ${siteMetadata.site.title}`}
  description={siteMetadata.archive.pageDescription}
>
  <main class="content-shell max-w-5xl py-8 sm:py-10 lg:py-12">
    <header class="pb-8">
      <p class="section-label">Archive</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-normal text-ink sm:text-4xl">{siteMetadata.archive.pageTitle}</h1>
      <p class="mt-3 max-w-2xl text-base leading-8 text-muted">{siteMetadata.archive.pageDescription}</p>
    </header>

    {
      entries.length === 0 ? (
        <p class="surface-panel p-5 text-sm text-muted">{siteMetadata.archive.emptyText}</p>
      ) : (
        <div class="grid gap-5">
          {Array.from(groups.entries()).map(([month, monthEntries]) => (
            <section class="surface-panel p-4 sm:p-5">
              <h2 class="text-lg font-semibold tracking-normal text-ink">{month}</h2>
              <ul class="mt-3 divide-y divide-line/70">
                {monthEntries.map((entry) => (
                  <li class="grid gap-2 py-3 sm:grid-cols-[7.5rem_minmax(0,1fr)] sm:items-baseline">
                    <time class="metadata-text whitespace-nowrap" datetime={`${entry.date}T${entry.time}`}>{entry.date} {entry.time}</time>
                    <a class="quiet-link font-medium" href={withBasePath(entry.permalink)}>{entry.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }
  </main>
</Layout>
