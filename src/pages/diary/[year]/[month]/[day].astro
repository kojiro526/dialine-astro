---
import EntryMediaGallery from '../../../../components/EntryMediaGallery.astro';
import Layout from '../../../../layouts/Layout.astro';
import { findDiaryDayByDate, findEntryById, listDiaryDays } from '../../../../lib/published-content';
import { withBasePath } from '../../../../lib/site-path';
import { loadSiteMetadata } from '../../../../lib/site-metadata';

export function getStaticPaths() {
  return listDiaryDays().map((day) => ({
    params: {
      year: day.year,
      month: day.month,
      day: day.day,
    },
  }));
}

const year = Astro.params.year ?? '';
const month = Astro.params.month ?? '';
const day = Astro.params.day ?? '';
const date = `${year}-${month}-${day}`;
const diaryDay = findDiaryDayByDate(date);

if (!diaryDay) {
  throw new Error(`Diary day not found: ${date}`);
}

const siteMetadata = loadSiteMetadata();
const dayEntries = diaryDay.entries.flatMap((entryRef) => {
  const entry = findEntryById(entryRef.id);
  return entry == null ? [] : [{ entryRef, entry }];
});
const diaryDayEntryCount = dayEntries.length;
const diaryDayDescription =
  diaryDay.excerpt || dayEntries[0]?.entry.excerpt || siteMetadata.site.description;
---

<Layout
  title={`${diaryDay.title} | ${siteMetadata.site.title}`}
  description={diaryDayDescription}
>
  <main class="content-shell py-8 sm:py-10 lg:py-12">
    <section class="grid gap-5 lg:grid-cols-[minmax(0,1.42fr)_minmax(280px,0.8fr)] lg:items-start">
      <article class="surface-panel p-5 sm:p-7">
        <header>
          <p class="section-label">Day</p>
          <h1 class="mt-3 text-2xl font-semibold leading-tight tracking-normal text-ink sm:text-3xl">{diaryDay.title}</h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-muted">
            この日の公開エントリーを時系列で表示しています。各エントリー末尾のリンクから個別ページへ移動できます。
          </p>
        </header>

        {
          dayEntries.length > 0 ? (
            <div class="mt-7 border-t border-line/60 pt-7">
              {dayEntries.map(({ entryRef, entry }, index) => {
                const EntryContent = entry.Content;
                const entryTime = entryRef.time || entry.time;
                const entryAt =
                  entryRef.entryAt ??
                  entry.entryAt ??
                  entry.updatedAt ??
                  entry.createdAt ??
                  `${entry.date}T${entry.time}:00Z`;

                return (
                  <section class:list={[
                    'py-1',
                    index < dayEntries.length - 1
                      ? 'mb-8 border-b border-line/60 pb-8'
                      : '',
                  ]}>
                    <div class="flex items-center justify-between gap-4">
                      <p class="section-label">Entry</p>
                      <time
                        class="metadata-text whitespace-nowrap"
                        datetime={entryAt}
                        data-format="time"
                      >
                        {entryTime}
                      </time>
                    </div>

                    {
                      typeof EntryContent === 'function' ? (
                        <div class="markdown-body mt-4">
                          <EntryContent />
                        </div>
                      ) : (
                        <p class="mt-4 text-sm text-muted">{siteMetadata.entry.contentUnavailableText}</p>
                      )
                    }

                    {
                      entry.images.length > 0 ? (
                        <EntryMediaGallery images={entry.images} />
                      ) : null
                    }

                    <p class="entry-footnote">
                      <time
                        class="entry-footnote-time"
                        datetime={entryAt}
                        data-format="time"
                      >
                        {entryTime}
                      </time>
                      <span class="entry-footnote-separator">·</span>
                      <a href={withBasePath(entryRef.url)}>投稿ページ</a>
                    </p>
                  </section>
                );
              })}
            </div>
          ) : (
            <p class="mt-7 border-t border-line/60 pt-7 text-sm text-muted">{siteMetadata.day.contentUnavailableText}</p>
          )
        }
      </article>

      <aside class="grid gap-5 lg:sticky lg:top-8">
        <section class="surface-panel p-4 sm:p-5">
          <p class="section-label">Overview</p>
          <dl class="mt-4 grid gap-4">
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Date</dt>
              <dd class="mt-1 text-base font-medium text-ink"><time datetime={`${diaryDay.date}T00:00:00Z`} data-format="logical-date" data-logical-date={diaryDay.date}>{diaryDay.date}</time></dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Entries</dt>
              <dd class="mt-1 text-base font-medium text-ink">{diaryDayEntryCount}件</dd>
            </div>
            {
              diaryDay.updatedAt ? (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Updated</dt>
                  <dd class="mt-1 break-all text-sm text-muted"><time datetime={diaryDay.updatedAt} data-format="datetime">{diaryDay.updatedAt}</time></dd>
                </div>
              ) : null
            }
          </dl>
        </section>

        <section class="surface-panel p-4 sm:p-5">
          <p class="section-label">Navigate</p>
          <div class="mt-4 grid gap-2">
            <a class="quiet-link rounded-md border border-line/80 bg-paper-soft px-3 py-2 font-medium" href={withBasePath('/')}>トップへ戻る</a>
            <a class="quiet-link rounded-md border border-line/80 bg-paper-soft px-3 py-2 font-medium" href={withBasePath('/archive/')}>アーカイブを見る</a>
          </div>
        </section>
      </aside>
    </section>
  </main>
</Layout>
