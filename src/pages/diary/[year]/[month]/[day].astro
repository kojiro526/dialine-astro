---
import Layout from '../../../../layouts/Layout.astro';
import { findDiaryDayByDate, listDiaryDays } from '../../../../lib/published-content';
import { withBasePath } from '../../../../lib/site-path';
import { loadSiteMetadata } from '../../../../lib/site-metadata';

export function getStaticPaths() {
  return listDiaryDays().map((day) => ({
    params: {
      year: day.year,
      month: day.month,
      day: day.day,
    },
  }));
}

const year = Astro.params.year ?? '';
const month = Astro.params.month ?? '';
const day = Astro.params.day ?? '';
const date = `${year}-${month}-${day}`;
const diaryDay = findDiaryDayByDate(date);
const siteMetadata = loadSiteMetadata();

if (!diaryDay) {
  throw new Error(`Diary day not found: ${date}`);
}

const DayContent = diaryDay.Content;
---

<Layout
  title={`${diaryDay.title} | ${siteMetadata.site.title}`}
  description={diaryDay.excerpt || siteMetadata.site.description}
>
  <main class="content-shell max-w-5xl py-8 sm:py-10 lg:py-12">
    <article class="surface-panel p-5 sm:p-7">
      <header>
        <p class="metadata-text">{diaryDay.date}</p>
        <h1 class="mt-3 text-2xl font-semibold leading-tight tracking-normal text-ink sm:text-3xl">{diaryDay.title}</h1>
      </header>

      {
        diaryDay.entries.length > 0 ? (
          <ul class="mt-6 grid gap-2 border-y border-line py-4">
            {diaryDay.entries.map((entry) => (
              <li class="grid gap-2 sm:grid-cols-[4.5rem_minmax(0,1fr)] sm:items-baseline">
                <span class="text-sm tabular-nums text-muted">{entry.time}</span>
                <a class="quiet-link font-medium" href={withBasePath(entry.url)}>{entry.id}</a>
              </li>
            ))}
          </ul>
        ) : null
      }

      {
        typeof DayContent === 'function' ? (
          <div class="markdown-body mt-7">
            <DayContent />
          </div>
        ) : (
          <p class="mt-7 text-sm text-muted">{siteMetadata.day.contentUnavailableText}</p>
        )
      }
    </article>
  </main>
</Layout>
