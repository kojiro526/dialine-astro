---
import Layout from '../../layouts/Layout.astro';
import { findEntryById, listEntries } from '../../lib/published-content';
import { withBasePath } from '../../lib/site-path';
import { loadSiteMetadata } from '../../lib/site-metadata';

export function getStaticPaths() {
  return listEntries().map((entry) => ({
    params: { id: entry.id },
  }));
}

const id = Astro.params.id ?? '';
const entry = findEntryById(id);
const siteMetadata = loadSiteMetadata();

if (!entry) {
  throw new Error(`Entry not found: ${id}`);
}

const EntryContent = entry.Content;
---

<Layout
  title={`${entry.title} | ${siteMetadata.site.title}`}
  description={entry.excerpt || siteMetadata.site.description}
>
  <main class="content-shell max-w-4xl py-8 sm:py-10 lg:py-12">
    <article class="surface-panel p-5 sm:p-7">
      <header>
        <p class="metadata-text">{entry.date} {entry.time}</p>
        <h1 class="mt-3 text-2xl font-semibold leading-tight tracking-normal text-ink sm:text-3xl">{entry.title}</h1>
        {
          entry.dayUrl ? (
            <p class="mt-4">
              <a class="inline-flex rounded-md border border-primary/20 bg-primary-soft px-3 py-1.5 text-sm font-medium text-primary no-underline transition-colors hover:border-primary/35 hover:bg-surface" href={withBasePath(entry.dayUrl)}>{siteMetadata.entry.backToDayLabel}</a>
            </p>
          ) : null
        }
      </header>

      {
        typeof EntryContent === 'function' ? (
          <div class="markdown-body mt-7 border-t border-line pt-7">
            <EntryContent />
          </div>
        ) : (
          <p class="mt-7 border-t border-line pt-7 text-sm text-muted">{siteMetadata.entry.contentUnavailableText}</p>
        )
      }
    </article>
  </main>
</Layout>
