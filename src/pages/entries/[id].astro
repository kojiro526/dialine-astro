---
import Layout from '../../layouts/Layout.astro';
import { findEntryById, listEntries } from '../../lib/published-content';
import { withBasePath } from '../../lib/site-path';
import { loadSiteMetadata } from '../../lib/site-metadata';

export function getStaticPaths() {
  return listEntries().map((entry) => ({
    params: { id: entry.id },
  }));
}

const id = Astro.params.id ?? '';
const entry = findEntryById(id);
const siteMetadata = loadSiteMetadata();

if (!entry) {
  throw new Error(`Entry not found: ${id}`);
}

const EntryContent = entry.Content;
---

<Layout
  title={`${entry.title} | ${siteMetadata.site.title}`}
  description={entry.excerpt || siteMetadata.site.description}
>
  <main class="content-shell py-8 sm:py-10 lg:py-12">
    <section class="grid gap-5 lg:grid-cols-[minmax(0,1.42fr)_minmax(280px,0.8fr)] lg:items-start">
      <article class="surface-panel p-5 sm:p-7">
        <header>
          <p class="section-label">Entry</p>
          <h1 class="mt-3 text-2xl font-semibold leading-tight tracking-normal text-ink sm:text-3xl">{entry.title}</h1>
        </header>

        {
          typeof EntryContent === 'function' ? (
            <div class="markdown-body mt-7 border-t border-line/60 pt-7">
              <EntryContent />
            </div>
          ) : (
            <p class="mt-7 border-t border-line/60 pt-7 text-sm text-muted">{siteMetadata.entry.contentUnavailableText}</p>
          )
        }

        {
          entry.images.length > 0 ? (
            <div class="entry-media-grid">
              {entry.images.map((image) => (
                <img
                  src={withBasePath(image.url)}
                  alt={image.alt}
                  width={image.width ?? undefined}
                  height={image.height ?? undefined}
                  loading="lazy"
                />
              ))}
            </div>
          ) : null
        }
      </article>

      <aside class="grid gap-5 lg:sticky lg:top-8">
        <section class="surface-panel p-4 sm:p-5">
          <p class="section-label">Overview</p>
          <dl class="mt-4 grid gap-4">
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Date</dt>
              <dd class="mt-1 text-base font-medium text-ink"><time datetime={`${entry.date}T00:00:00Z`} data-format="logical-date" data-logical-date={entry.date}>{entry.date}</time></dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Time</dt>
              <dd class="mt-1 text-base font-medium tabular-nums text-ink"><time datetime={entry.entryAt ?? `${entry.date}T${entry.time}:00Z`} data-format="time">{entry.time}</time></dd>
            </div>
            {
              entry.updatedAt ? (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-[0.12em] text-primary-muted">Updated</dt>
                  <dd class="mt-1 break-all text-sm text-muted"><time datetime={entry.updatedAt} data-format="datetime">{entry.updatedAt}</time></dd>
                </div>
              ) : null
            }
          </dl>
        </section>

        <section class="surface-panel p-4 sm:p-5">
          <p class="section-label">Navigate</p>
          <div class="mt-4 grid gap-2">
            {
              entry.dayUrl ? (
                <a class="quiet-link rounded-md border border-primary/20 bg-primary-soft px-3 py-2 font-medium text-primary" href={withBasePath(entry.dayUrl)}>{siteMetadata.entry.backToDayLabel}</a>
              ) : null
            }
            <a class="quiet-link rounded-md border border-line/80 bg-paper-soft px-3 py-2 font-medium" href={withBasePath('/archive/')}>アーカイブを見る</a>
            <a class="quiet-link rounded-md border border-line/80 bg-paper-soft px-3 py-2 font-medium" href={withBasePath('/')}>トップへ戻る</a>
          </div>
        </section>
      </aside>
    </section>
  </main>
</Layout>
