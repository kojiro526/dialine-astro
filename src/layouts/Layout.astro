---
import '../styles/global.css';
import { toLogicalPath, withBasePath } from '../lib/site-path';
import { loadSiteMetadata } from '../lib/site-metadata';

interface Props {
	title?: string;
	description?: string;
}

const siteMetadata = loadSiteMetadata();
const {
	title = siteMetadata.site.title,
	description = siteMetadata.site.description,
} = Astro.props;

const pathname = toLogicalPath(Astro.url.pathname) ?? '/';
const avatarPath = withBasePath(
	siteMetadata.profile.avatarImagePath ?? '/media/profile/default-avatar.svg',
);
const faviconPath = siteMetadata.profile.faviconImagePath
	? withBasePath(siteMetadata.profile.faviconImagePath)
	: null;
const avatarAlt = `${siteMetadata.site.title} avatar`;

const navItems = [
	{
		label: siteMetadata.navigation.homeLabel,
		href: withBasePath('/'),
		active: pathname === '/',
	},
	{
		label: siteMetadata.navigation.archiveLabel,
		href: withBasePath('/archive/'),
		active: pathname.startsWith('/archive/'),
	},
	{
		label: siteMetadata.navigation.rssLabel,
		href: withBasePath('/rss.xml'),
		active: false,
	},
];
---

<!doctype html>
<html lang={siteMetadata.site.language}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{
			faviconPath ? (
				<>
					<link rel="icon" type="image/png" href={faviconPath} />
					<link rel="apple-touch-icon" href={faviconPath} />
				</>
			) : (
				<>
					<link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
					<link rel="icon" href={withBasePath('/favicon.ico')} />
				</>
			)
		}
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen text-ink antialiased">
		<div class="grid min-h-screen grid-rows-[auto_1fr_auto]">
			<header class="border-b border-line/70 bg-paper-soft/82 backdrop-blur">
				<div class="content-shell flex flex-col gap-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:py-5">
					<a class="inline-flex items-center gap-3 text-lg font-semibold tracking-normal text-ink no-underline" href={withBasePath('/')}>
						<img
							class="site-avatar site-avatar--header"
							src={avatarPath}
							alt={avatarAlt}
							width="48"
							height="48"
						/>
						<span>{siteMetadata.site.title}</span>
						<span class="hidden h-1.5 w-1.5 rounded-full bg-primary sm:inline-block"></span>
					</a>
					<nav class="flex flex-wrap items-center gap-2" aria-label="Primary navigation">
						{navItems.map((item) => (
							<a
								class:list={[
									'rounded-md border px-3 py-1.5 text-sm font-medium no-underline transition-colors',
									item.active
										? 'border-primary/25 bg-primary-soft text-primary'
										: 'border-transparent text-muted hover:border-line hover:bg-surface hover:text-ink',
								]}
								href={item.href}
								aria-current={item.active ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</div>
			</header>

			<slot />

			<footer class="border-t border-line/60">
				<p class="content-shell py-6 text-sm text-muted">{siteMetadata.site.footerText}</p>
			</footer>
		</div>
		<script is:inline>
			const logicalDateFormatter = new Intl.DateTimeFormat(undefined, {
				dateStyle: 'medium',
				timeZone: 'UTC',
			});
			const localTimeFormatter = new Intl.DateTimeFormat(undefined, {
				hour: '2-digit',
				minute: '2-digit',
				hour12: false,
			});
			const localDateTimeFormatter = new Intl.DateTimeFormat(undefined, {
				dateStyle: 'medium',
				timeStyle: 'short',
				hour12: false,
			});

			function parseLogicalDate(value) {
				if (!value) {
					return null;
				}

				const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
				if (!match) {
					return null;
				}

				return new Date(
					Date.UTC(Number(match[1]), Number(match[2]) - 1, Number(match[3])),
				);
			}

			function parseInstant(value) {
				if (!value) {
					return null;
				}

				const parsed = new Date(value);
				return Number.isNaN(parsed.getTime()) ? null : parsed;
			}

			function applyLocalizedTimes() {
				document.querySelectorAll('time[data-format]').forEach((element) => {
					const logicalDate = parseLogicalDate(
						element.getAttribute('data-logical-date'),
					);
					const instant = parseInstant(element.getAttribute('datetime'));
					const format = element.getAttribute('data-format');

					if (format === 'logical-date' && logicalDate) {
						element.textContent = logicalDateFormatter.format(logicalDate);
						return;
					}

					if (format === 'time' && instant) {
						element.textContent = localTimeFormatter.format(instant);
						return;
					}

					if (format === 'datetime' && instant) {
						element.textContent = localDateTimeFormatter.format(instant);
						return;
					}

					if (format === 'logical-date-time' && logicalDate && instant) {
						element.textContent = `${logicalDateFormatter.format(logicalDate)} ${localTimeFormatter.format(instant)}`;
					}
				});
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', applyLocalizedTimes, {
					once: true,
				});
			} else {
				applyLocalizedTimes();
			}
		</script>
	</body>
</html>
