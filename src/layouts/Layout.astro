---
import '../styles/global.css';
import { toLogicalPath, withBasePath } from '../lib/site-path';
import { loadSiteMetadata } from '../lib/site-metadata';

interface Props {
	title?: string;
	description?: string;
}

const siteMetadata = loadSiteMetadata();
const {
	title = siteMetadata.site.title,
	description = siteMetadata.site.description,
} = Astro.props;

const pathname = toLogicalPath(Astro.url.pathname) ?? '/';

const navItems = [
	{
		label: siteMetadata.navigation.homeLabel,
		href: withBasePath('/'),
		active: pathname === '/',
	},
	{
		label: siteMetadata.navigation.archiveLabel,
		href: withBasePath('/archive/'),
		active: pathname.startsWith('/archive/'),
	},
	{
		label: siteMetadata.navigation.rssLabel,
		href: withBasePath('/rss.xml'),
		active: false,
	},
];
---

<!doctype html>
<html lang={siteMetadata.site.language}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
		<link rel="icon" href={withBasePath('/favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen text-ink antialiased">
		<div class="grid min-h-screen grid-rows-[auto_1fr_auto]">
			<header class="border-b border-line/70 bg-paper-soft/82 backdrop-blur">
				<div class="content-shell flex flex-col gap-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:py-5">
					<a class="inline-flex items-baseline gap-2 text-lg font-semibold tracking-normal text-ink no-underline" href={withBasePath('/')}>
						<span>{siteMetadata.site.title}</span>
						<span class="hidden h-1.5 w-1.5 rounded-full bg-primary sm:inline-block"></span>
					</a>
					<nav class="flex flex-wrap items-center gap-2" aria-label="Primary navigation">
						{navItems.map((item) => (
							<a
								class:list={[
									'rounded-md border px-3 py-1.5 text-sm font-medium no-underline transition-colors',
									item.active
										? 'border-primary/25 bg-primary-soft text-primary'
										: 'border-transparent text-muted hover:border-line hover:bg-surface hover:text-ink',
								]}
								href={item.href}
								aria-current={item.active ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</div>
			</header>

			<slot />

			<footer class="border-t border-line/60">
				<p class="content-shell py-6 text-sm text-muted">{siteMetadata.site.footerText}</p>
			</footer>
		</div>
	</body>
</html>
